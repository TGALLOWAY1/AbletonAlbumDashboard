# Finish Five — environment variables.
# Copy to `.env.local` for local dev; set the same keys in your host (Vercel).
# Never commit real values — `.env*` is gitignored.

# --- Supabase (public, safe to expose to the browser) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Supabase service_role (SERVER-ONLY SECRET) ---
# Bypasses Row Level Security. Required once RLS is enabled on the user tables.
# NEVER prefix with NEXT_PUBLIC_ and never commit the real value — leaking it
# grants full read/write to the entire database.
# Found in: Supabase Dashboard → Project Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- App ---
# Single-user owner id used to scope every row.
NEXT_PUBLIC_OWNER_ID=00000000-0000-0000-0000-000000000001
